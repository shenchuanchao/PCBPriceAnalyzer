<UserControl x:Class="PCBPriceAnalyzer.WPF.Views.DataSourceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewModels="clr-namespace:PCBPriceAnalyzer.WPF.ViewModels"
             xmlns:entities="clr-namespace:PCBPriceAnalyzer.Models.Entities;assembly=PCBPriceAnalyzer.Models"
             xmlns:converters="clr-namespace:PCBPriceAnalyzer.WPF.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance viewModels:DataSourceViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题和新增按钮 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button Content="导入黄金期货数据" Command="{Binding ImportGoldDataCommand}" 
            Padding="10,5" Margin="0,0,10,0" Background="LightBlue"/>
            <Button Content="新增数据源" Command="{Binding NewDataSourceCommand}" 
                    Padding="10,5" Margin="0,0,10,0"/>
        </StackPanel>

        <!-- 主内容区：列表和编辑表单 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" MinWidth="350"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧数据源列表 -->
            <Border Style="{StaticResource CardStyle}" Grid.Column="0" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="数据源列表" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding DataSources}" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectedItem="{Binding SelectedDataSource}"
                              SelectionMode="Single"
                              AlternatingRowBackground="#F5F5F5" AlternationCount="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="100"/>
                            <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="70"/>
                            <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="150"/>
                            <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="50"/>
                            <DataGridTextColumn Header="最后采集" Binding="{Binding LastFetchTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="120"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding FetchStatus}" Width="60"/>
                            <DataGridTemplateColumn Header="操作" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="编辑" Command="{Binding DataContext.EditDataSourceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Margin="2" Padding="5,2"/>
                                            <Button Content="测试" Command="{Binding DataContext.TestConnectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Margin="2" Padding="5,2"/>
                                            <Button Content="采集" Command="{Binding DataContext.FetchNowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Margin="2" Padding="5,2"/>
                                            <Button Content="删除" Command="{Binding DataContext.DeleteDataSourceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Margin="2" Padding="5,2"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 右侧编辑/新增表单 -->
            <Border Style="{StaticResource CardStyle}" Grid.Column="1" Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Margin="5">
                    <TextBlock Text="{Binding SelectedDataSource, Converter={x:Static converters:NullToTextConverter.Instance}, ConverterParameter=新增数据源, FallbackValue=编辑数据源}" 
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="名称" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding Name}" Margin="0,0,0,5"/>

                    <TextBlock Text="类型" Margin="0,5,0,2"/>
                    <ComboBox ItemsSource="{Binding DataSourceTypes}" SelectedItem="{Binding Type}" Margin="0,0,0,5"/>

                    <TextBlock Text="URL" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding Url}" Margin="0,0,0,5"/>

                    <TextBlock Text="API密钥" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding ApiKey}" Margin="0,0,0,5"/>

                    <CheckBox Content="启用" IsChecked="{Binding IsEnabled}" Margin="0,5,0,5"/>

                    <TextBlock Text="更新间隔（分钟）" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding UpdateInterval}" Margin="0,0,0,5"/>

                    <TextBlock Text="描述" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding Description}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="保存" Command="{Binding SaveDataSourceCommand}" Padding="15,5" Margin="5"/>
                        <Button Content="取消" Command="{Binding CancelEditCommand}" Padding="15,5" Margin="5"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 加载指示器 -->
        <ProgressBar IsIndeterminate="True" Height="4" 
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Grid.RowSpan="2" VerticalAlignment="Top"/>
    </Grid>
</UserControl>
