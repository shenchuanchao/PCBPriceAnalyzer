<Application x:Class="PCBPriceAnalyzer.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PCBPriceAnalyzer.WPF"
             xmlns:viewModels="clr-namespace:PCBPriceAnalyzer.WPF.ViewModels"
             xmlns:views="clr-namespace:PCBPriceAnalyzer.WPF.Views">
    <Application.Resources>
        <!-- 视图模型到视图的映射 -->
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PriceHistoryViewModel}">
            <views:PriceHistoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PredictionViewModel}">
            <views:PredictionView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:DataSourceViewModel}">
            <views:DataSourceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Application.Resources>
</Application>
