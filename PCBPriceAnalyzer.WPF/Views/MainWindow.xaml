<Window x:Class="PCBPriceAnalyzer.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:PCBPriceAnalyzer.WPF.ViewModels"
        mc:Ignorable="d"
        Title="PCB原材料价格智能分析" Height="600" Width="900"
        d:DataContext="{d:DesignInstance viewModels:MainViewModel}"
        WindowStartupLocation="CenterScreen">
   

    <DockPanel>
        <!-- 顶部菜单栏 -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="文件">
                <MenuItem Header="导入数据" Command="{Binding ImportDataCommand}"/>
                <MenuItem Header="导出报告" Command="{Binding ExportReportCommand}"/>
                <Separator />
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="工具">
                <MenuItem Header="刷新数据" Command="{Binding RefreshDataCommand}"/>
                <MenuItem Header="设置" Command="{Binding NavigateToCommand}" CommandParameter="{Binding NavigationItems[3]}"/>
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="关于" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- 左侧导航栏 -->
        <ListBox x:Name="NavigationListBox" 
                 DockPanel.Dock="Left" 
                 Width="180" 
                 ItemsSource="{Binding NavigationItems}"
                 SelectedItem="{Binding NavigationItems[0], Mode=OneTime}" 
                 Margin="5"
                 Background="#F0F0F0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" Margin="5"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <EventSetter Event="MouseLeftButtonUp" Handler="NavigationItem_MouseLeftButtonUp"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- 右侧内容区域 -->
        <Border Margin="5" Padding="5" Background="White" CornerRadius="5">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>
    </DockPanel>

</Window>
